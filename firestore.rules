rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: true when the caller is a verified admin ──────────────────
    // Uses exists() before get() to avoid a null-data error when the user
    // document hasn't been created yet, and .get('isAdmin', false) for safe
    // map access. Works for both document reads AND list/aggregation queries.
    function isAdmin() {
      return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid))
               .data.get('isAdmin', false) == true;
    }

    // ── Admin panel: full access to every path ────────────────────────────
    // Single recursive wildcard /{document=**} is the correct global match
    // that covers documents, list queries, AND aggregation queries (count).
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ── users ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── matches ───────────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if request.auth != null
          && (resource.data.uid1 == request.auth.uid
           || resource.data.uid2 == request.auth.uid);
    }

    // ── moments ───────────────────────────────────────────────────────────
    match /moments/{momentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
          && resource.data.uid == request.auth.uid;
    }

    // ── winks ─────────────────────────────────────────────────────────────
    match /winks/{winkId} {
      allow read: if request.auth != null
          && (resource.data.fromUid == request.auth.uid
           || resource.data.toUid   == request.auth.uid);
      allow create: if request.auth != null
          && request.resource.data.fromUid == request.auth.uid;
    }

    // ── reports ───────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if request.auth != null;
    }

    // ── photoReviews ──────────────────────────────────────────────────────
    match /photoReviews/{reviewId} {
      allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
    }

    // ── appConfig ─────────────────────────────────────────────────────────
    match /appConfig/{docId} {
      allow read: if request.auth != null;
    }
  }
}
